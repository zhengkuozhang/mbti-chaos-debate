# ==============================================================================
# MBTI Chaos Debate · Environment Configuration Template
# ------------------------------------------------------------------------------
# 使用方式:
#   1. cp .env.example .env
#   2. 根据本机硬件调整 GLOBAL_LLM_CONCURRENCY 与 OLLAMA_MODEL_*
#   3. docker compose up -d
# ------------------------------------------------------------------------------
# ⚠️ 严禁将填充后的 .env 文件提交至版本控制 (.gitignore 已收录)。
# ==============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# [SECTION 1] 应用运行环境
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
# 可选值: DEBUG | INFO | WARNING | ERROR | CRITICAL

# ─────────────────────────────────────────────────────────────────────────────
# [SECTION 2] Ollama 宿主机直连 (Metal/GPU 直通核心配置)
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️ 物理隔离铁律: Ollama 必须裸跑于 macOS 宿主机,严禁容器化。
# host.docker.internal 是容器访问宿主机的标准 DNS 名,Docker Desktop 自动注入。
# Linux 部署需在 docker-compose.yml 中保留 extra_hosts 映射 (已配置)。
OLLAMA_HOST=http://host.docker.internal:11434

# 各角色使用的模型 tag (需提前 ollama pull):
#   - 主推理模型: 推荐 qwen2.5:14b-instruct-q4_K_M (10GB VRAM, 性价比最高)
#   - 摘要模型 :  推荐 qwen2.5:3b-instruct-q4_K_M  (后台低优先级,轻量化)
OLLAMA_MODEL_PRIMARY=qwen2.5:14b-instruct-q4_K_M
OLLAMA_MODEL_SUMMARIZER=qwen2.5:3b-instruct-q4_K_M

# Ollama 单次请求超时 (秒) —— 与全局看门狗共同构成熔断兜底
OLLAMA_REQUEST_TIMEOUT_SEC=45

# ─────────────────────────────────────────────────────────────────────────────
# [SECTION 3] 全局算力控流 (防 OOM 死锁的最后防线)
# ─────────────────────────────────────────────────────────────────────────────
# 同一时刻允许向 Ollama 发起的并发推理数。
# 推荐值参照:
#   - M3 Pro 18GB :  1
#   - M2 Max 32GB :  2
#   - M3 Max 64GB :  3
# 严禁超过 3。Ollama 内部并不做精细队列,过高会触发 metal allocator 抖动。
GLOBAL_LLM_CONCURRENCY=2

# 全局超时看门狗 (秒) —— 单轮 Agent 发言最长允许时长
# 触发后强制 response.aclose() + 影子上下文回写,杜绝僵尸返回值。
LLM_REQUEST_TIMEOUT_SEC=45

# ─────────────────────────────────────────────────────────────────────────────
# [SECTION 4] ChromaDB 向量记忆层
# ─────────────────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=mbti_debate_memory
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# 写入队列容量 —— 单线程 Worker 的环形缓冲
CHROMA_WRITE_QUEUE_MAXSIZE=512

# ─────────────────────────────────────────────────────────────────────────────
# [SECTION 5] WebSocket 防风暴节流
# ─────────────────────────────────────────────────────────────────────────────
# 状态包(Aggro/FSM) 推送频率,单位 Hz。文本流不受此限,实时推送。
WS_STATE_PUSH_HZ=10

# 单连接最大消息长度 (字节) —— 防恶意构造
WS_MAX_MESSAGE_BYTES=65536

# ─────────────────────────────────────────────────────────────────────────────
# [SECTION 6] Aggro 引擎物理参数 (量纲: 时间一律为 [秒])
# ─────────────────────────────────────────────────────────────────────────────
# 衰减系数默认值 λ (单位: 1/秒)。e^(-λ·Δt) 中 Δt 也必须为秒。
# 0.05 表示约 14 秒衰减至初始值的 50%。
AGGRO_LAMBDA_DEFAULT=0.05

# Aggro 上下界 (绝对边界,触底不归零、触顶不爆炸)
AGGRO_MIN=0.0
AGGRO_MAX=100.0

# 抢话阈值: Aggro >= 此值时,Agent 进入仲裁器中断申请队列
AGGRO_INTERRUPT_THRESHOLD=85.0

# ─────────────────────────────────────────────────────────────────────────────
# [SECTION 7] 上下文与短记忆窗口
# ─────────────────────────────────────────────────────────────────────────────
# 短记忆保留最近 N 轮发言, 超出后由后台 Summarizer 压缩归档至 ChromaDB。
SHORT_MEMORY_WINDOW_TURNS=8

# 滑动缓冲区: 前缀拦截最大字符数 (超过仍未匹配则降级为纯文本流)
STREAM_PREFIX_BUFFER_MAX_CHARS=20

# ─────────────────────────────────────────────────────────────────────────────
# [SECTION 8] 安全 / CORS
# ─────────────────────────────────────────────────────────────────────────────
# 允许的前端来源 (生产环境严格收敛)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173